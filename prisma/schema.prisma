// Try Prisma Accelerate: https://pris.ly/cli/accelerate-init

generator client {
  provider = "prisma-client"
  output   = "../generated/prisma"
  
  // fix bug: exports is not defined in ES module scope
  // link: https://github.com/prisma/prisma/issues/27556
  moduleFormat = "cjs"
}

datasource db {
  provider = "postgresql"

}
model User {
  id String @id @default(cuid())
  email String @unique 
  password String // hash sau
  fullName String @map("full_name")
  avatarUrl String? @map("avatar_url")
  role Role @default(STUDENT)

  // Thông tin mở rộng
  phoneNumber String? @map("phone_number")
  dateOfBirth DateTime? @map("date_of_birth")
  address String? @map("address")
  faculty String? @map("faculty") // Khoa (dành cho giảng viên/học sinh)
  studentId String? @unique @map("student_id") // MSSV
  employeeId String? @unique @map("employee_id") // MSGV
  

  // Metadata: thông tin mô tả dữ liệu
  isActive Boolean @default(true) @map("is_active")
  lastLogin DateTime? @map("last_log_in")
  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  @@map("users") // mapping model vào database
  courses Course[]
  enrollments Enrollment[]
}

model Course{
  id String @id @default(cuid())
  title String @map("title")
  description String @map("description")
  rate Float @default(0) @map("rate")
  level Level @default(Beginner) @map("level")
  duration String? @map("duration")
  thumbnail String? @map("thumbnail")
  totalStudent Int? @default(0) @map("total_student")

  //Foreign key
  instructorId String
  instructor User @relation(fields: [instructorId], references: [id])

  isActive Boolean @default(true) @map("is_active")
  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  @@unique([instructorId])
  @@map("courses")
  enrollments Enrollment[]
}

model Enrollment{
  id String @id @default(cuid())
  userId String @map("user_id")
  user User @relation(fields: [userId], references: [id])
  courseId String @map("course_id")
  course Course @relation(fields: [courseId], references: [id])
  progress Float @default(0) @map("progress")
  lastAccessIn DateTime @default(now()) @map("last_access_in")
  completedAt DateTime? @map("completed_at")
  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  @@unique([userId,courseId])
  @@map("enrollments")
}

enum Role {
  STUDENT
  INSTRUCTOR
  ACADEMIC_AFFAIRS_OFFICE // phòng đào tạo
  FACULTY_OFFICE // phòng khoa
}
enum Level {
  Beginner
  Intermediate
  Expert
}