// learn more about it in the docs: https://pris.ly/d/prisma-schema

// Looking for ways to speed up your queries, or scale easily with your serverless or edge functions?
// Try Prisma Accelerate: https://pris.ly/cli/accelerate-init

generator client {
  provider = "prisma-client"
  output   = "../generated/prisma"
  
  // fix bug: exports is not defined in ES module scope
  // link: https://github.com/prisma/prisma/issues/27556
  moduleFormat = "cjs"
}

datasource db {
  provider = "postgresql"

}
// ENUM
enum Level {
  Beginner
  Intermediate
  Expert
}
enum Enroll_Status {
  ACTIVE
  COMPLETED
  DROPPED
}
enum Course_Status {
  DRAFT
  PUBLISHED
  ARCHIVE
}
enum Lesson_Type {
  VIDEO
  TEXT
  QUIZ
  ASSIGNMENT
}

//===================================
//        MODELS
//===================================
model User {
  id String @id @default(uuid())
  email String @unique 
  password String // hash sau
  fullName String @map("full_name")
  avatarUrl String? @map("avatar_url")

  //FK
  roleId String
  

  // Thông tin mở rộng
  phoneNumber String? @map("phone_number")
  dateOfBirth DateTime? @map("date_of_birth")
  address String? 
  faculty String?  // Khoa (dành cho giảng viên/học sinh)
  studentId String? @unique @map("student_id") // MSSV
  employeeId String? @unique @map("employee_id") // MSGV
  

  // Metadata: thông tin mô tả dữ liệu
  isActive Boolean @default(true) @map("is_active")
  lastLogin DateTime? @map("last_log_in")
  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  // FK ref
  role Role @relation(fields: [roleId], references: [id])
  courses Course[]
  enrollments Enrollment[]

  
  @@index([roleId])
  @@map("users")
}
model Role {
  id String @id @default(uuid())
  role_name String @unique
  description String?
  
  users User[]
  role_permission Role_Permission[]

  @@map("roles")
}
model Permission {
  id String @id @default(uuid())
  name String // course:create
  resource String // course, student,...
  action String

  roles_permissions Role_Permission[]

  @@map("permissions")
}
model Role_Permission {
  roleId String
  permissionId String
  role Role @relation(fields: [roleId], references: [id])
  permission Permission @relation(fields: [permissionId], references: [id])

  @@id([roleId,permissionId])
  @@map("roles_permissions")
}
model Course{
  id String @id @default(uuid())
  title String 
  description String 
  rate Float @default(0) 
  level Level @default(Beginner) 
  durationHours Int? @map("duration_hours")
  thumbnail String? 
  totalStudent Int? @default(0) @map("total_student")
  status Course_Status @default(DRAFT)

  //Foreign key
  instructorId String @map("instructor_id")
  

  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  enrollments Enrollment[]
  instructor User @relation(fields: [instructorId], references: [id])
  lessons Lesson[]

  @@map("courses")
  @@index([instructorId])
  @@unique([instructorId])
}
/*
Ý tưởng thiết kế: Phân loại khóa học theo danh mục (có thể phân cấp).
Mục đích: Giúp người học dễ dàng tìm kiếm khóa học theo lĩnh vực.
Mục tiêu: Hỗ trợ điều hướng, gợi ý khóa học theo danh mục, phân tích xu hướng.
Ví dụ: phân loại khoá học theo ngành "CNTT", và trong đó sẽ còn các chuyên ngành như "Lập trình web"
*/
model Course_Category{
  id String @id @default(uuid())
  name String @unique
  parentId String?

  parent Course_Category? @relation("CategoryHierchary", fields: [parentId], references: [id])
  children Course_Category[] @relation("CategoryHierchary")

  @@index([parentId])
  @@map("course_categories")
}
model Lesson {
  id String @id @default(uuid())
  title String 
  description String?
  order Int? // thứ tự xuất hiện của bài học
  type Lesson_Type
  durationMinutes Int @map("duration_minutes")
  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  courseId String
  course Course @relation(fields: [courseId], references: [id])

  @@unique([courseId,order])
  @@map("lessons")
}
model Enrollment{
  id String @id @default(uuid())
  userId String @map("user_id")
  courseId String @map("course_id")
  enrollAt DateTime @default(now()) @map("enroll_at")
  completedAt DateTime? @map("completed_at")
  status Enroll_Status

  user User @relation(fields: [userId], references: [id])
  course Course @relation(fields: [courseId], references: [id])
  

  @@unique([userId,courseId])
  @@map("enrollments")
}

